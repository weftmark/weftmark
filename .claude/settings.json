{
  "permissions": {
    "allow": [
      "Bash(docker compose exec backend python -c ' *)",
      "Bash(docker compose *)",
      "Bash(docker cp *)",
      "Bash(conda run *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(npx tsc *)",
      "Bash(npm run *)",
      "Bash(curl -s http://localhost:3000/health)",
      "Bash(curl -s http://10.10.10.90:3000/api/*)",
      "Bash(python -c ' *)",
      "Bash(python .claude/hooks/session_start.py)",
      "Bash(python -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\('Title:', d['title']\\); print\\('State:', d['state']\\); print\\('Body:'\\); print\\(d['body']\\)\")"
    ],
    "additionalDirectories": [
      "d:\\repos\\weaving_site",
      "d:\\repos\\weaving_site\\backend"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_start.py 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Loading active issue from Gitea..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -qE 'docker compose build|docker build' && docker image prune -f 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
