      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "topk(10, sum by (country) (rate(weftmark_user_logins_total{deployment_environment=~\"$env\", country!=\"\"}[$__rate_interval])))",
          "legendFormat": "{{country}}",
          "refId": "A"
        }
      ],
