# Base URL of the environment under test
E2E_BASE_URL=https://dev.weftmark.com

# Cloudflare Access service token — needed when E2E_BASE_URL points to dev.weftmark.com
# Create at: Cloudflare Dashboard → Access → Service Auth → Create Service Token
# Grant it access to the "wa0rc-web" Access application
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Regular approved user (is_admin=false, eula accepted)
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Admin user (is_admin=true)
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
