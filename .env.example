# ============================================================
# WeftMark — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored. This file is tracked.
# ============================================================


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Secret key for signing sessions and tokens (generate with: openssl rand -hex 32)
APP_SECRET_KEY=

# Runtime environment — controls HSTS, CSP, and other security features
# Values: "dev" (local development) | "production" (deployed environment)
APP_ENV=dev

# Dev banner color — visually distinguishes local, dev, and staging instances (ignored in production).
# Suggested: indigo, blue, teal, green, purple, pink, red
# Leave unset to use the default amber/yellow.
# VITE_DEV_BANNER_COLOR=indigo

# Allow the CLI seed command to run — set to "true" in dev only, never in production
SEED_ENABLED=false

# Docker Compose profiles to activate (comma-separated).
# "local-db" — start a local PostgreSQL container (omit when using a managed DB such as Neon)
# "worker02" — start a second Celery worker (worker2) for task isolation and extra capacity
# Example: COMPOSE_PROFILES=local-db,worker02
COMPOSE_PROFILES=

# Set to "true" in development only — enables debug output and auto-reload
DEBUG=false

# Allow the CLI seed command to run (set to "true" only on a fresh local instance)
SEED_ENABLED=false

# Log level for the backend: DEBUG, INFO, WARNING, ERROR (default: INFO)
# Output is always structured JSON for observability platform ingestion.
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins for the API
# Dev:  CORS_ORIGINS=https://dev.weftmark.com,http://localhost:3000
# Prod: CORS_ORIGINS=https://weftmark.com
CORS_ORIGINS=http://localhost:3000

# Public URL of the frontend (used for generating share links)
FRONTEND_URL=http://localhost:3000

# Public URL of the API (used by the frontend to reach the backend)
API_URL=http://localhost:8000


# ------------------------------------------------------------
# Deployment — Docker Compose / Komodo
# ------------------------------------------------------------

# Registry image tag to pull for frontend and backend
# Dev stack:  IMAGE_TAG=dev
# Prod stack: IMAGE_TAG=latest  (or a pinned version tag)
IMAGE_TAG=latest

# Prefix for all container names, Docker network names, and volume names.
# Use a unique value per stack so dev and prod can coexist on the same host.
# Dev stack:  STACK_NAME=weftmark-dev
# Prod stack: STACK_NAME=weftmark
STACK_NAME=weftmark

# Host-side port for the local PostgreSQL container (local-db profile only).
# Change if the default conflicts with another Postgres instance on the host.
DB_HOST_PORT=5432


# ------------------------------------------------------------
# Database — PostgreSQL (application)
#
# Local dev: leave POSTGRES_DSN / POSTGRES_DSN_DIRECT blank and fill in POSTGRES_* vars.
#
# Managed Postgres (e.g. Neon): set both DSN vars and leave POSTGRES_* vars alone.
#   POSTGRES_DSN        — pooled connection (PgBouncer) used by the running app
#   POSTGRES_DSN_DIRECT — direct connection used by Alembic migrations only
#                         (required; DDL transactions don't work through PgBouncer)
#   If POSTGRES_DSN_DIRECT is blank, Alembic falls back to POSTGRES_DSN.
#
# Neon example:
#   POSTGRES_DSN=postgresql://user:pw@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
#   POSTGRES_DSN_DIRECT=postgresql://user:pw@ep-xxx.region.aws.neon.tech/db?sslmode=require
# ------------------------------------------------------------
POSTGRES_DSN=
POSTGRES_DSN_DIRECT=
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=weaving_site
POSTGRES_USER=weaving_user
POSTGRES_PASSWORD=


# ------------------------------------------------------------
# Authentication — Clerk
# Create an application at https://dashboard.clerk.com/
# All three values are found under "API Keys" in your Clerk dashboard.
# ------------------------------------------------------------

# Publishable key — injected into the frontend container at runtime (not baked into the image).
# Local Vite dev also needs VITE_CLERK_PUBLISHABLE_KEY set to the same value (see below).
CLERK_PUBLISHABLE_KEY=

# Secret key — backend only, never expose to the browser (sk_test_... or sk_live_...)
CLERK_SECRET_KEY=

# Webhook signing secret — Clerk Dashboard → Webhooks → your endpoint → Signing Secret
# Register the endpoint as: https://your-domain.com/auth/clerk/webhook
# Subscribe to: user.created, user.deleted
# Looks like: whsec_...
CLERK_WEBHOOK_SECRET=

# Override base URL for webhook delivery (optional — falls back to API_URL when blank)
# Probe appends /auth/clerk/webhook and posts to that URL to verify round-trip delivery.
# Set this when API_URL goes through an auth-gated proxy (e.g. Cloudflare Access) that
# would block the backend's outbound probe request with a redirect:
#   WEBHOOK_BASE_URL=http://localhost:8000   ← Docker deployments (bypasses proxy)
# Also set when local dev uses a tunnel so Clerk can reach the endpoint:
#   WEBHOOK_BASE_URL=https://your-tunnel.ngrok-free.app
WEBHOOK_BASE_URL=

# Cloudflare Zero Trust — service token for webhook probe (optional)
# When CF_ZERO_TRUST_ENABLED=true, the webhook probe includes CF Access service token
# headers so the probe request traverses the full public path (Cloudflare → Traefik →
# nginx → backend) rather than looping back internally.
# Setup: Cloudflare Zero Trust → Access → Service Auth → Service Tokens → Create token,
# then add a policy rule on the dev.weftmark.com application: Allow → Service Token.
# Leave CF_ZERO_TRUST_ENABLED=false (default) on environments without Cloudflare Access.
CF_ZERO_TRUST_ENABLED=false
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Clerk redirect paths — configure code-side instead of via the Clerk dashboard.
# These are baked into the frontend at build time via Vite and match the app routes.
VITE_CLERK_SIGN_IN_URL=/login
VITE_CLERK_SIGN_UP_URL=/register
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/home
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/home

# Local Vite dev only — same value as CLERK_PUBLISHABLE_KEY above.
# The Docker container reads CLERK_PUBLISHABLE_KEY at runtime instead.
VITE_CLERK_PUBLISHABLE_KEY=


# ------------------------------------------------------------
# File Storage
# In production, point these at object storage (S3-compatible).
# In development, files are stored on the local filesystem.
# ------------------------------------------------------------

# Local upload directory (mounted as a Docker volume in dev)
UPLOAD_DIR=/app/uploads

# Maximum upload file size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800

# Storage backend: "local" or "s3"
STORAGE_BACKEND=local

# S3-compatible storage (required if STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=


# ------------------------------------------------------------
# Email — SMTP2Go
# Used for sending invitation emails.
# ------------------------------------------------------------
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=WeftMark

# Default invite link expiry in days (admins can override per invite)
INVITE_EXPIRY_DAYS_DEFAULT=7


# ------------------------------------------------------------
# Redis — Celery broker and result backend
# For Docker deployments: redis://redis:6379/0 (service name matches compose)
# For external Redis: redis://:password@host:6379/0
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0


# ------------------------------------------------------------
# PyWeaving / Rendering
# ------------------------------------------------------------

# Maximum image dimensions for rendered design previews (pixels)
RENDER_MAX_WIDTH=4000
RENDER_MAX_HEIGHT=4000

# Default zoom level for rendered previews
RENDER_DEFAULT_ZOOM=10


# ------------------------------------------------------------
# Celery worker
# ------------------------------------------------------------

# Number of concurrent worker processes per worker container.
# I/O-bound tasks (CVE scan, S3 audit) benefit from values above
# the CPU core count; CPU-bound tasks (image rendering) should stay
# at or below the core count to avoid context-switch overhead.
CELERY_CONCURRENCY=2

# Enable the second Celery worker by adding "worker02" to COMPOSE_PROFILES (see top of file).
# Both worker and worker2 use the same CELERY_CONCURRENCY value.

# Number of days after soft-deletion before records are permanently purged.
# Applies to drafts, looms, projects, and yarn (not users — handled separately).
# Triggered manually from Admin → Superuser → Maintenance or via a scheduled task.
SOFT_DELETE_RETENTION_DAYS=365


# ------------------------------------------------------------
# OpenTelemetry — observability (traces, metrics, logs)
# Leave OTEL_EXPORTER_OTLP_ENDPOINT empty to disable telemetry.
# When enabled, the backend, workers, and beat containers must be
# attached to the same Docker network as the otelcol receiver
# (see docker-compose.yml → networks → observability_receiver).
# ------------------------------------------------------------

# Base URL of the OTLP HTTP receiver (port 4318).
# Example: http://observability_otel-collector:4318
# Leave empty in local dev — SDK no-ops gracefully when unset.
OTEL_EXPORTER_OTLP_ENDPOINT=
