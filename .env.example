# ============================================================
# Weaving Site — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored. This file is tracked.
# ============================================================


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Secret key for signing sessions and tokens (generate with: openssl rand -hex 32)
APP_SECRET_KEY=

# Set to "true" in development only — enables debug output and auto-reload
DEBUG=false

# Comma-separated list of allowed CORS origins for the API
# Example: http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Public URL of the frontend (used for generating share links)
FRONTEND_URL=http://localhost:3000

# Public URL of the API (used by the frontend to reach the backend)
API_URL=http://localhost:8000


# ------------------------------------------------------------
# Database — PostgreSQL (application)
# ------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=weaving_site
POSTGRES_USER=weaving_user
POSTGRES_PASSWORD=


# ------------------------------------------------------------
# Redis
# Shared between Celery (task queue) and application caching
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Celery broker and result backend
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2


# ------------------------------------------------------------
# Authentication — OIDC
# Authentik is the reference provider for local development.
# Any OIDC-compliant provider is supported via these variables.
# ------------------------------------------------------------

# OIDC discovery endpoint (Authentik example shown)
# Format: https://<authentik-host>/application/o/<app-slug>/
OIDC_DISCOVERY_URL=http://authentik-server:9000/application/o/weaving-site/

# Client credentials — created in your OIDC provider
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Where the OIDC provider should redirect after login
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback


# ------------------------------------------------------------
# Authentik (local development OIDC provider)
# These variables configure the Authentik container itself.
# Not needed if using a different OIDC provider.
# ------------------------------------------------------------

# Secret key for Authentik (generate with: openssl rand -hex 32)
AUTHENTIK_SECRET_KEY=

# Authentik's own PostgreSQL connection
AUTHENTIK_POSTGRESQL__HOST=db
AUTHENTIK_POSTGRESQL__PORT=5432
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__USER=authentik_user
AUTHENTIK_POSTGRESQL__PASSWORD=

# Authentik Redis connection
AUTHENTIK_REDIS__HOST=redis

# Disable error reporting to Sentry in local dev
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# Authentik admin bootstrap credentials (first-run only)
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=


# ------------------------------------------------------------
# File Storage
# In production, point these at object storage (S3-compatible).
# In development, files are stored on the local filesystem.
# ------------------------------------------------------------

# Local upload directory (mounted as a Docker volume in dev)
UPLOAD_DIR=/app/uploads

# Maximum upload file size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800

# Storage backend: "local" or "s3"
STORAGE_BACKEND=local

# S3-compatible storage (required if STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=


# ------------------------------------------------------------
# PyWeaving / Rendering
# ------------------------------------------------------------

# Maximum image dimensions for rendered design previews (pixels)
RENDER_MAX_WIDTH=4000
RENDER_MAX_HEIGHT=4000

# Default zoom level for rendered previews
RENDER_DEFAULT_ZOOM=10
