# ============================================================
# WeftMark — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored. This file is tracked.
# ============================================================


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Secret key for signing sessions and tokens (generate with: openssl rand -hex 32)
APP_SECRET_KEY=

# Set to "true" in development only — enables debug output and auto-reload
DEBUG=false

# Comma-separated list of allowed CORS origins for the API
# Example: http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Public URL of the frontend (used for generating share links)
FRONTEND_URL=http://localhost:3000

# Public URL of the API (used by the frontend to reach the backend)
API_URL=http://localhost:8000


# ------------------------------------------------------------
# Database — PostgreSQL (application)
#
# Local dev: leave POSTGRES_DSN blank and fill in POSTGRES_* vars.
# Production (Neon or other managed Postgres): set POSTGRES_DSN to the
# full connection string — the individual POSTGRES_* vars are ignored.
# Neon connection strings look like:
#   postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# ------------------------------------------------------------
POSTGRES_DSN=
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=weaving_site
POSTGRES_USER=weaving_user
POSTGRES_PASSWORD=


# ------------------------------------------------------------
# Redis
# Shared between Celery (task queue) and application caching
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# Celery broker and result backend
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2


# ------------------------------------------------------------
# Authentication — Google OIDC
# Create OAuth 2.0 credentials at https://console.cloud.google.com/
# Authorized redirect URI must include OIDC_REDIRECT_URI below.
# ------------------------------------------------------------

# Google OIDC discovery endpoint
OIDC_DISCOVERY_URL=https://accounts.google.com

# Client credentials — from Google Cloud Console → APIs & Services → Credentials
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Where Google should redirect after login (must match Google Console setting)
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback


# ------------------------------------------------------------
# File Storage
# In production, point these at object storage (S3-compatible).
# In development, files are stored on the local filesystem.
# ------------------------------------------------------------

# Local upload directory (mounted as a Docker volume in dev)
UPLOAD_DIR=/app/uploads

# Maximum upload file size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800

# Storage backend: "local" or "s3"
STORAGE_BACKEND=local

# S3-compatible storage (required if STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=


# ------------------------------------------------------------
# Email — SMTP2Go
# Used for sending invitation emails.
# ------------------------------------------------------------
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=WeftMark

# Default invite link expiry in days (admins can override per invite)
INVITE_EXPIRY_DAYS_DEFAULT=7


# ------------------------------------------------------------
# PyWeaving / Rendering
# ------------------------------------------------------------

# Maximum image dimensions for rendered design previews (pixels)
RENDER_MAX_WIDTH=4000
RENDER_MAX_HEIGHT=4000

# Default zoom level for rendered previews
RENDER_DEFAULT_ZOOM=10
