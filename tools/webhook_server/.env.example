# Gitea webhook secret — must match the secret set in Gitea webhook config
WEBHOOK_SECRET=change-me

# Port this server listens on
PORT=3001

# Full path to the claude CLI binary
# On Windows the binary is inside the VS Code extension:
# C:\Users\<you>\.vscode\extensions\anthropic.claude-code-<version>-win32-x64\resources\native-binary\claude.exe
CLAUDE_BIN=claude

# Absolute path to the weaving_site repo root (claude runs with this as cwd)
REPO_PATH=d:/repos/weaving_site

# Gitea instance
GITEA_BASE_URL=http://10.10.10.90:3000
GITEA_REPO=gx1400/weaving_site

# Gitea token used to post comments back (needs write:issue scope)
# In Claude Code sessions this is already injected from ~/.claude/settings.json — leave blank.
# When running as a standalone service (systemd etc.) set it here.
GITEA_TOKEN=
