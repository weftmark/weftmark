{
  "name": "Protect dev",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/dev"],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 0,
        "dismiss_stale_reviews_on_push": false,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": false
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": false,
        "required_status_checks": [
          { "context": "Runner smoke test",                          "integration_id": null },
          { "context": "Backend lint (ruff)",                        "integration_id": null },
          { "context": "Frontend lint (eslint)",                     "integration_id": null },
          { "context": "Frontend type check (tsc)",                  "integration_id": null },
          { "context": "Backend tests (pytest)",                     "integration_id": null },
          { "context": "Alembic migration smoke test",               "integration_id": null },
          { "context": "Dependency audit — backend (pip-audit)",     "integration_id": null },
          { "context": "Dependency audit — frontend (npm audit)",    "integration_id": null },
          { "context": "Docker build — backend",                     "integration_id": null },
          { "context": "Docker build — frontend",                    "integration_id": null }
        ]
      }
    }
  ],
  "bypass_actors": [
    {
      "actor_id": YOUR_WEFTMARK_BOT_INSTALLATION_ID,
      "actor_type": "Integration",
      "bypass_mode": "always"
    }
  ]
}
